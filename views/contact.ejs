<!DOCTYPE html>
<html lang="es">
    <head>
        <title>Contacto-MiCineteca</title>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta name="description" content="Pagina contacto. Mi cineteca">
        <meta name="author" content="Javier Cabrera">
        <meta name="keywords" content="cine, cinefilo, bilioteca, social-media, peliculas, films, descubre, actores">
        <link rel="stylesheet" href="/stylesheets/style.css">
        <link rel="stylesheet" href="/stylesheets/contact.css">
    </head>
    <body>
        <header>
            <%- include("partials/navBar") %>            
        </header>
        <main>
            <section id="soporte">
                <h1 class="contact-title">Centro de Soporte</h1>
                <p class="contact-subtitle">¿Tienes algún problema o duda? <br>Estamos aquí para ayudarte</p>
                <div class="container">
                    <div class="contact-form">
                        <form action="#" method="POST">

                            <div class="form-group">
                                <label for="name">Nombre:</label>
                                <input type="text" name="name" id="name" placeholder="Nombre">
                            </div>

                            <div class="form-group">
                                <label for="mail">Correo electrónico:</label>
                                <input type="email" name="mail" id="mail" placeholder="user@example.com">
                            </div>

                            <div class="form-group">
                                <label for="message">Mensaje o descripcion del problema:</label>
                                <textarea name="message" id="message" placeholder="Escribe aqui..."></textarea>
                            </div>

                            <button type="submit" class="btn-primary">Enviar</button>

                        </form>
                    </div>
                    <div class="contact-details">
                        <p>
                            <strong>Direccion:</strong>
                            <span>C/Inventada,36. Madrid, España</span>
                        </p>

                        <p>
                            <strong>Correo electrónico</strong>
                            <span>cineteca.soporte@micineteca.com</span>
                        </p>

                        <p>
                            <strong>Teléfono:</strong>
                            <span>955-87-69-34</span>
                        </p>

                        <div class="map-contact">
                            <iframe 
                                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3191.303922743176!2d-4.44518380678689!3d36.68893051897469!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd72f9d1ad2c3d95%3A0x2e62408338fb171b!2sLa%20T%C3%A9rmica!5e1!3m2!1ses-419!2ses!4v1732373909504!5m2!1ses-419!2ses"  
                                title="Mapa cineteca en Madrid"
                                loading="lazy" 
                                referrerpolicy="no-referrer-when-downgrade">
                            </iframe>
                        </div>

                    </div>
                </div>
            </section>
        </main>
        <%- include("partials/footer") %> 
    </body>
</html>