<!DOCTYPE html>
<html lang="es">
    <head>
        <title><%= title %></title>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta name="description" content="Organiza, explora y ordena tus películas.">
        <meta name="author" content="Javier Cabrera">
        <meta name="keywords" content="cine, cinefilo, bilioteca, social-media, peliculas, films, descubre, actores">
        <link rel="stylesheet" href="/stylesheets/style.css">
    </head>
    <body>
        <header>
            <%- include("partials/navBar") %>
        </header>
        <main>
            <section class="hero">
                <div class="hero-left">
                    <h1>Tu colección de cine, siempre contigo</h1>
                    <p>Gestiona tus copias, descubre nueva películas y mantén tu cineteca organizada</p>
                    <div class="hero-btns">
                        <a href="/#list" class="btn-primary">Explorar películas</a>
                        <a href="/myCollection" class="btn-secondary">Ver mi colección</a>
                    </div>
                </div>
                <div class="hero-right">
                    <img src="images/coleccion-pelis.jpg" alt="image hero section">
                </div>
            </section>
            <section class="filmList" id="list">
                <h2>Últimas películas añadidas</h2>
                <div class="inner">
                    <% films.forEach(pelicula => { %>
                        <a href="/film/<%= pelicula.id %>">
                            <%- include("partials/filmCards",{peli : pelicula }) %>  
                        </a>
                    <% }); %> 
                </div>
            </section>
        </main>
        <%- include("partials/footer") %>
    </body>
</html>
